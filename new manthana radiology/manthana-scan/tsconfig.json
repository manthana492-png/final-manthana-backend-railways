{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@manthana/api": ["../../packages/frontend-api/src"],
      "@manthana/api/*": ["../../packages/frontend-api/src/*"],
      "@manthana/domain": ["../../packages/frontend-domain/src"],
      "@manthana/domain/*": ["../../packages/frontend-domain/src/*"],
      "@manthana/ui": ["../../packages/frontend-ui/src"],
      "@manthana/ui/*": ["../../packages/frontend-ui/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
