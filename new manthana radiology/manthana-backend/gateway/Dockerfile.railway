# Slim gateway for Railway (no torch / transformers / chromadb).
# Includes manthana-inference + cloud_inference.yaml so /ai/detect-modality and llm_router work.
#
# Build context MUST be the repo root that contains BOTH `packages/` AND `config/`
# (e.g. `this_studio/`), NOT `manthana-backend/` alone — Railway "Root Directory" must
# be empty or the monorepo root, otherwise COPY of packages/config fails.
#
# Local:
#   cd this_studio
#   docker build -f "new manthana radiology/manthana-backend/gateway/Dockerfile.railway" -t manthana-gateway .
#
# Railway: Root Directory = repo root · Dockerfile path =
#   new manthana radiology/manthana-backend/gateway/Dockerfile.railway

FROM python:3.11-slim AS builder

WORKDIR /build
COPY ["new manthana radiology/manthana-backend/gateway/requirements-railway.txt", "./requirements.txt"]
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

FROM python:3.11-slim

WORKDIR /app
COPY --from=builder /install /usr/local

COPY ["packages/manthana-inference", "/app/packages/manthana-inference"]
COPY ["config/cloud_inference.yaml", "/app/config/cloud_inference.yaml"]

RUN pip install --no-cache-dir -e /app/packages/manthana-inference

COPY ["new manthana radiology/manthana-backend/gateway", "/app"]
COPY ["new manthana radiology/manthana-backend/shared", "/app/shared"]

ENV MANTHANA_LLM_REPO_ROOT=/app
ENV CLOUD_INFERENCE_CONFIG_PATH=/app/config/cloud_inference.yaml
ENV PYTHONPATH=/app:/app/shared

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
