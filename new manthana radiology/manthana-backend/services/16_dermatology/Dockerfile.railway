# Production image: EfficientNet-B4 (optional weights) + OpenRouter dermatology role + llm_router stack.
# CPU-first; no CUDA base required.
#
# Build context MUST be `this_studio`:
#   cd this_studio
#   docker build -f "new manthana radiology/manthana-backend/services/16_dermatology/Dockerfile.railway" -t manthana-dermatology .

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY ["packages/manthana-inference", "/app/packages/manthana-inference"]
COPY ["config/cloud_inference.yaml", "/app/config/cloud_inference.yaml"]

RUN pip install --no-cache-dir -U pip setuptools wheel \
    && pip install --no-cache-dir -e /app/packages/manthana-inference \
    && pip install --no-cache-dir "instructor>=1.0.0"

COPY ["new manthana radiology/manthana-backend/services/16_dermatology/requirements.txt", "/tmp/derm-req.txt"]
RUN pip install --no-cache-dir -r /tmp/derm-req.txt

COPY ["new manthana radiology/manthana-backend/shared", "/app/shared"]
COPY ["new manthana radiology/manthana-backend/services/16_dermatology", "/app"]

ENV MANTHANA_LLM_REPO_ROOT=/app
ENV PYTHONPATH=/app:/app/shared
ENV CLOUD_INFERENCE_CONFIG_PATH=/app/config/cloud_inference.yaml
ENV MODEL_DIR=/models

EXPOSE 8016

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8016"]
