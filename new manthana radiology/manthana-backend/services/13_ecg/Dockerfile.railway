# Production / Railway image with OpenRouter narrative_ecg support (llm_router + cloud_inference).
#
# Build context MUST be `this_studio` (repo root that contains `packages/` and `config/`):
#   cd this_studio
#   docker build -f "new manthana radiology/manthana-backend/services/13_ecg/Dockerfile.railway" -t manthana-ecg .
#
# For local dev with only docker-compose from manthana-backend, see docker-compose.yml `ecg` service.

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 libsm6 libxrender1 libxext6 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY ["packages/manthana-inference", "/app/packages/manthana-inference"]
COPY ["config/cloud_inference.yaml", "/app/config/cloud_inference.yaml"]

RUN pip install --no-cache-dir -U pip setuptools wheel \
    && pip install --no-cache-dir -e /app/packages/manthana-inference \
    && pip install --no-cache-dir "instructor>=1.0.0"

COPY ["new manthana radiology/manthana-backend/services/13_ecg/requirements.txt", "/tmp/ecg-requirements.txt"]
RUN pip install --no-cache-dir -r /tmp/ecg-requirements.txt

COPY ["new manthana radiology/manthana-backend/shared", "/app/shared"]
COPY ["new manthana radiology/manthana-backend/services/13_ecg", "/app"]

ENV MANTHANA_LLM_REPO_ROOT=/app
ENV PYTHONPATH=/app:/app/shared
ENV CLOUD_INFERENCE_CONFIG_PATH=/app/config/cloud_inference.yaml

EXPOSE 8013

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8013"]
