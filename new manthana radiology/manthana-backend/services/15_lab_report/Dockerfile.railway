# Production image: MedGemma (medical_document_parser) + llm_router (manthana-inference + cloud_inference.yaml).
#
# Build context MUST be `this_studio`:
#   cd this_studio
#   docker build -f "new manthana radiology/manthana-backend/services/15_lab_report/Dockerfile.railway" -t manthana-lab-report .

FROM nvidia/cuda:12.4.0-runtime-ubuntu22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev \
    libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

WORKDIR /app

COPY ["packages/manthana-inference", "/app/packages/manthana-inference"]
COPY ["config/cloud_inference.yaml", "/app/config/cloud_inference.yaml"]

RUN pip install --no-cache-dir -U pip setuptools wheel \
    && pip install --no-cache-dir -e /app/packages/manthana-inference \
    && pip install --no-cache-dir "instructor>=1.0.0"

COPY ["new manthana radiology/manthana-backend/services/15_lab_report/requirements.txt", "/tmp/lab-req.txt"]
RUN pip install --no-cache-dir -r /tmp/lab-req.txt

COPY ["new manthana radiology/manthana-backend/shared", "/app/shared"]
COPY ["new manthana radiology/manthana-backend/services/15_lab_report", "/app"]

ENV MANTHANA_LLM_REPO_ROOT=/app
ENV PYTHONPATH=/app:/app/shared
ENV CLOUD_INFERENCE_CONFIG_PATH=/app/config/cloud_inference.yaml
ENV MODEL_DIR=/models
ENV MANTHANA_MODEL_CACHE=/models

EXPOSE 8015

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8015"]
