# ╔══════════════════════════════════════════════════════════╗
# ║          MANTHANA RADIOLOGY SUITE — ENV CONFIG          ║
# ╚══════════════════════════════════════════════════════════╝
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ════════════════════════════════════════════════════════════
# CLOUD LLM — OpenRouter only (single source of truth)
# ════════════════════════════════════════════════════════════
# Models and roles: repository config/cloud_inference.yaml (mount or set path below).
# Default Labs + narrative primary: moonshotai/kimi-k2.5:online; fallbacks: gpt-4o-mini:online, Llama 3.3 70B (see YAML).
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Optional second key for rotation / rate limits
OPENROUTER_API_KEY_2=
# Absolute path inside containers if YAML is not next to code (default: auto from package layout)
CLOUD_INFERENCE_CONFIG_PATH=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Manthana

# llm_router task routing (always uses OpenRouter; strategy reserved)
LLM_ROUTING_STRATEGY=openrouter

# CXR: require cloud narrative (503 when OPENROUTER missing). Legacy env name still read: XRAY_REQUIRE_KIMI_NARRATIVE
XRAY_REQUIRE_LLM_NARRATIVE=1
# Idle model memory policy for TorchXRayVision:
XRAY_MODEL_IDLE_UNLOAD_SEC=180
XRAY_UNLOAD_MODE=gpu_only
XRAY_MODEL_IDLE_CHECK_SEC=15

# MRI / CT narrative: off | openrouter (default). Legacy values map to openrouter.
MRI_NARRATIVE_POLICY=openrouter
MRI_NARRATIVE_VISION=1
CT_SPINE_NARRATIVE_POLICY=openrouter
CT_ABDOMINAL_NARRATIVE_POLICY=openrouter
CT_BRAIN_NARRATIVE_POLICY=openrouter
CT_CARDIAC_NARRATIVE_POLICY=off

# Dermatology upload limits (optional)
# DERM_MAX_UPLOAD_BYTES=15728640
# DERM_MAX_IMAGE_PIXELS=36000000
# DERM_SCORE_MAX_TOKENS=8192
# DERM_NARRATIVE_MAX_TOKENS=16384

# ════════════════════════════════════════════════════════════
# HARDWARE CONFIGURATION
# ════════════════════════════════════════════════════════════
DEVICE=cuda                             # "cuda" on GPU server, "cpu" for CPU-only
MODEL_DIR=/models                       # Where weights auto-download and cache
GPU_MEMORY_FRACTION=0.85                # Max GPU RAM % for model loading

# ════════════════════════════════════════════════════════════
# INFRASTRUCTURE
# ════════════════════════════════════════════════════════════
# Async job queue (Redis) — OFF by default. Labs / gateway work without Redis (sync /analyze).
# Enable only if you use RQ: set USE_REDIS_QUEUE=1 and a reachable REDIS_URL (Upstash, ElastiCache, or
#   docker compose --profile queue up for bundled redis + queue_api + queue_worker).
# USE_REDIS_QUEUE=1
# REDIS_URL=redis://redis:6379/0

# Vector Store for Embeddings
VECTOR_STORE_BACKEND=chroma
CHROMA_PERSIST_DIR=/models/vector_db

# ════════════════════════════════════════════════════════════
# GATEWAY SECURITY
# ════════════════════════════════════════════════════════════
GATEWAY_PORT=8000
# Legacy: tokens minted by gateway auth_routes / pilots
JWT_SECRET=change-this-to-a-random-secret-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
# Supabase (Next.js app): JWT secret from Supabase Dashboard → Project Settings → API → JWT Secret
# Verifies browser access tokens (HS256, aud=authenticated). When set, tried before JWT_SECRET.
SUPABASE_JWT_SECRET=
# Optional: restrict iss to your project, e.g. https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_ISS=
# X-ray triage policy: always_deep | threshold
XRAY_TRIAGE_POLICY=always_deep
# Used only when XRAY_TRIAGE_POLICY=threshold
TRIAGE_ABNORMALITY_THRESHOLD=0.30
# Backward compatibility switch (equivalent to XRAY_TRIAGE_POLICY=always_deep)
SKIP_XRAY_TRIAGE=1

# ════════════════════════════════════════════════════════════
# HUGGINGFACE (Model Downloads)
# ════════════════════════════════════════════════════════════
HF_TOKEN=hf_xxx                         # Required for gated models
HF_HOME=/models/.huggingface

# ════════════════════════════════════════════════════════════
# LAB REPORT — MedGemma (shared/medical_document_parser → google/medgemma-4b-it)
# ════════════════════════════════════════════════════════════
USE_MEDGEMMA_PARSER=auto                # always | never | auto (legacy: USE_PARROTV_PARSER)
LAB_DEVICE=cuda                         # lab_report service DEVICE in docker-compose
# Gateway overrides (production): point to Modal lab URL or Railway GPU
# LAB_REPORT_SERVICE_URL=http://lab_report:8015/analyze/lab_report
# DERMATOLOGY_SERVICE_URL=http://dermatology:8016/analyze/dermatology
# Production on Modal: ORAL_CANCER_SERVICE_URL=https://<user>--manthana-oral-cancer-<hash>.modal.run/analyze/oral_cancer
# ORAL_CANCER_SERVICE_URL=http://oral_cancer:8014/analyze/oral_cancer

# ════════════════════════════════════════════════════════════
# ORAL CANCER (14_oral_cancer) — Production: Modal GPU deploy_oral_cancer.py (T4)
# ════════════════════════════════════════════════════════════
# ORAL_DEVICE=cpu                       # docker-compose oral_cancer service DEVICE (Modal GPU stub sets cuda)
# ORAL_CANCER_ENABLED=true
# UNI_MODEL_ID=MahmoodLab/UNI           # histopath path; HF_TOKEN may be required
# Optional checkpoints under MODEL_DIR:
#   oral_cancer_finetuned.pt, oral_effnet_v2m.pt, uni_oral_linear_head.pt

# ════════════════════════════════════════════════════════════
# SERVICE PORTS (Internal Docker Network)
# ════════════════════════════════════════════════════════════
PORT_GATEWAY=8000
PORT_BODY_XRAY=8001
PORT_BRAIN_MRI=8002
PORT_CARDIAC_CT=8004
PORT_PATHOLOGY=8005
PORT_ABDOMINAL_CT=8008
PORT_ULTRASOUND=8009
PORT_SPINE_NEURO=8010
PORT_CYTOLOGY=8011
PORT_MAMMOGRAPHY=8012
PORT_ECG=8013
PORT_ORAL_CANCER=8014
PORT_LAB_REPORT=8015
PORT_DERMATOLOGY=8016
PORT_REPORT=8020
PORT_QUEUE_API=8021

# ════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                         # json | text

# ════════════════════════════════════════════════════════════
# PACS (Orthanc DICOM Server)
# ════════════════════════════════════════════════════════════
ORTHANC_URL=http://orthanc:8042
ORTHANC_USERNAME=manthana
ORTHANC_PASSWORD=manthana-pacs-secret
ORTHANC_DB_PASSWORD=manthana_pacs_2024
ORTHANC_AET=MANTHANA
PORT_ORTHANC_HTTP=8042
PORT_ORTHANC_DICOM=4242
PORT_PACS_BRIDGE=8030

# ════════════════════════════════════════════════════════════
# HOSPITAL PACS CONNECTION (Optional)
# ════════════════════════════════════════════════════════════
# HOSPITAL_PACS_AET=HOSPITAL
# HOSPITAL_PACS_HOST=192.168.1.100
# HOSPITAL_PACS_PORT=11112
