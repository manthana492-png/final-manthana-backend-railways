# ╔══════════════════════════════════════════════════════════╗
# ║          MANTHANA RADIOLOGY SUITE — ENV CONFIG          ║
# ╚══════════════════════════════════════════════════════════╝
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ════════════════════════════════════════════════════════════
# PRIMARY LLM — Google Gemini 2.0 Flash Lite (direct API)
# ════════════════════════════════════════════════════════════
GEMINI_API_KEY=your-google-ai-studio-key-here
GEMINI_MODEL=gemini-2.0-flash-lite

# ════════════════════════════════════════════════════════════
# SECONDARY LLM — DeepSeek V3 (fallback if Gemini fails)
# ════════════════════════════════════════════════════════════
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat                  # V3 model

# ════════════════════════════════════════════════════════════
# LONG-CONTEXT & COMPLEX REASONING — Kimi 2.5 (Moonshot AI)
# ════════════════════════════════════════════════════════════
# OpenAI-compatible: pip install openai; base_url + api_key. See:
#   https://platform.moonshot.ai/docs/guide/kimi-k2-5-quickstart
# Match KIMI_BASE_URL to your key: .ai (international) vs .cn (China) or 401.
KIMI_API_KEY=sk-your-kimi-key-here
KIMI_BASE_URL=https://api.moonshot.ai/v1
# Primary K2.5 id: kimi-k2.5 (multimodal). Legacy: moonshot-v1-8k / 32k / 128k
KIMI_MODEL=kimi-k2.5
# X-ray policy: require Kimi narrative for all xray outputs (503 when unavailable)
XRAY_REQUIRE_KIMI_NARRATIVE=1
# Idle model memory policy for TorchXRayVision:
# 0 disables idle unload, >0 unloads after idle seconds.
XRAY_MODEL_IDLE_UNLOAD_SEC=180
# gpu_only: move model to CPU RAM; full: remove model object from RAM.
XRAY_UNLOAD_MODE=gpu_only
# Background checker interval for idle unload loop
XRAY_MODEL_IDLE_CHECK_SEC=15
# Dermatology service (16_dermatology): uses KIMI_* above; optional overrides:
# KIMI_DERMATOLOGY_MODEL=kimi-k2.5
# KIMI_DERMATOLOGY_THINKING=enabled   # or disabled (Moonshot API: enabled | disabled only)
# KIMI_DERMATOLOGY_TIMEOUT_SEC=240
# KIMI_DERMATOLOGY_MAX_RETRIES=2
# DERM_MAX_UPLOAD_BYTES=15728640
# DERM_MAX_IMAGE_PIXELS=36000000

# ════════════════════════════════════════════════════════════
# FALLBACK LLMs (Optional but recommended for redundancy)
# ════════════════════════════════════════════════════════════
# Groq (free tier includes e.g. llama-3.3-70b-versatile, llama-3.1-8b-instant — list: GET https://api.groq.com/openai/v1/models)
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# QWEN_API_KEY=xxx                    # Optional fallback
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# QWEN_MODEL=qwen-max

# ════════════════════════════════════════════════════════════
# LLM ROUTING STRATEGY
# ════════════════════════════════════════════════════════════
# Options:
# - "deepseek"        : Always use DeepSeek V3
# - "kimi"            : Always use Kimi 2.5
# - "smart"           : Route based on task (recommended)
#   • Lab Reports → DeepSeek (fast, structured)
#   • Unified Reports → Kimi (long context, synthesis)
#   • Complex Cases → Kimi (multi-step reasoning)
#   • Fallback → Groq (speed)
LLM_ROUTING_STRATEGY=smart

# Enable Kimi for specific high-value tasks
USE_KIMI_FOR_UNIFIED_REPORTS=true
USE_KIMI_FOR_LONG_DOCUMENTS=true
KIMI_CONTEXT_THRESHOLD=8000             # Use Kimi if prompt > 8k tokens

# ════════════════════════════════════════════════════════════
# HARDWARE CONFIGURATION
# ════════════════════════════════════════════════════════════
DEVICE=cuda                             # "cuda" on GPU server, "cpu" for CPU-only
MODEL_DIR=/models                       # Where weights auto-download and cache
GPU_MEMORY_FRACTION=0.85                # Max GPU RAM % for model loading

# ════════════════════════════════════════════════════════════
# INFRASTRUCTURE
# ════════════════════════════════════════════════════════════
REDIS_URL=redis://redis:6379/0

# Vector Store for Embeddings
VECTOR_STORE_BACKEND=chroma
CHROMA_PERSIST_DIR=/models/vector_db

# ════════════════════════════════════════════════════════════
# GATEWAY SECURITY
# ════════════════════════════════════════════════════════════
GATEWAY_PORT=8000
JWT_SECRET=change-this-to-a-random-secret-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
# X-ray triage policy: always_deep | threshold
XRAY_TRIAGE_POLICY=always_deep
# Used only when XRAY_TRIAGE_POLICY=threshold
TRIAGE_ABNORMALITY_THRESHOLD=0.30
# Backward compatibility switch (equivalent to XRAY_TRIAGE_POLICY=always_deep)
SKIP_XRAY_TRIAGE=1

# ════════════════════════════════════════════════════════════
# HUGGINGFACE (Model Downloads)
# ════════════════════════════════════════════════════════════
HF_TOKEN=hf_xxx                         # Required for gated models
HF_HOME=/models/.huggingface

# ════════════════════════════════════════════════════════════
# MEDICAL DOCUMENT PARSER (Parrotlet-v-lite-4b)
# ════════════════════════════════════════════════════════════
USE_PARROTV_PARSER=auto                 # always | never | auto
PARROTV_DEVICE=cuda                     # cuda or cpu

# ════════════════════════════════════════════════════════════
# SERVICE PORTS (Internal Docker Network)
# ════════════════════════════════════════════════════════════
PORT_GATEWAY=8000
PORT_BODY_XRAY=8001
PORT_BRAIN_MRI=8002
PORT_CARDIAC_CT=8004
PORT_PATHOLOGY=8005
PORT_ABDOMINAL_CT=8008
PORT_ULTRASOUND=8009
PORT_SPINE_NEURO=8010
PORT_CYTOLOGY=8011
PORT_MAMMOGRAPHY=8012
PORT_ECG=8013
PORT_ORAL_CANCER=8014
PORT_LAB_REPORT=8015
PORT_REPORT=8020
PORT_QUEUE_API=8021

# ════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                         # json | text

# ════════════════════════════════════════════════════════════
# PACS (Orthanc DICOM Server)
# ════════════════════════════════════════════════════════════
ORTHANC_URL=http://orthanc:8042
ORTHANC_USERNAME=manthana
ORTHANC_PASSWORD=manthana-pacs-secret
ORTHANC_DB_PASSWORD=manthana_pacs_2024
ORTHANC_AET=MANTHANA
PORT_ORTHANC_HTTP=8042
PORT_ORTHANC_DICOM=4242
PORT_PACS_BRIDGE=8030

# ════════════════════════════════════════════════════════════
# HOSPITAL PACS CONNECTION (Optional)
# ════════════════════════════════════════════════════════════
# HOSPITAL_PACS_AET=HOSPITAL
# HOSPITAL_PACS_HOST=192.168.1.100
# HOSPITAL_PACS_PORT=11112
