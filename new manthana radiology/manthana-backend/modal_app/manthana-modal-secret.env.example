# =============================================================================
# Manthana — Modal secret template for `manthana-env` (production-oriented)
# =============================================================================
# 1. Copy to manthana-modal-secret.env (gitignored):
#      copy modal_app\manthana-modal-secret.env.example modal_app\manthana-modal-secret.env
# 2. Replace every REPLACE_* or fill empty values. Never commit the filled file.
# 3. Push to Modal:
#      python -m modal secret create manthana-env --force --from-dotenv "FULL_PATH\modal_app\manthana-modal-secret.env"
#
# Railway-only vars (JWT, Supabase, REDIS, REPORT_ASSEMBLY, *_SERVICE_URL, XRAY_TRIAGE_POLICY) do NOT belong here.
# Volume mount in containers: /models  →  use paths like /models/ct_brain/ich_main.pt
# =============================================================================

# --- OpenRouter (required for narratives / llm_router across Modal services) ---
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY
OPENROUTER_API_KEY_2=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Manthana
CLOUD_INFERENCE_CONFIG_PATH=
LLM_ROUTING_STRATEGY=openrouter

# --- Modal volume + LLM repo layout (must match deploy stubs) ---
MODEL_DIR=/models
MANTHANA_LLM_REPO_ROOT=/app
HF_HOME=/models/.huggingface

# --- TotalSegmentator (optional bootstrap / licensed tasks) ---
# 18-character academic key from https://backend.totalsegmentator.com/license-academic/
# Enables ``vertebrae_body`` / ``heartchambers`` when MANTHANA_TOTALSEG_BOOTSTRAP_TASKS lists them.
TOTALSEG_LICENSE_NUMBER=
# Comma-separated tasks for ``modal run modal_app/bootstrap_weights.py`` (default: total,total_mr)
# MANTHANA_TOTALSEG_BOOTSTRAP_TASKS=total,total_mr,vertebrae_body

# --- Hugging Face (pathology, cytology, mammography Mirai, oral UNI, lab MedGemma, etc.) ---
HF_TOKEN=
HUGGINGFACE_TOKEN=

# --- CT brain (11_ct_brain) + VISTA-3D premium app ---
CT_BRAIN_NARRATIVE_POLICY=openrouter
CT_BRAIN_TORCHSCRIPT_PATH=/models/ct_brain/ich_main.pt
CT_BRAIN_SUBTYPE_MODEL_PATH=
CT_BRAIN_SEGMENTATION_MODEL_PATH=
CT_BRAIN_CRITICAL_THRESHOLD=0.5
CT_BRAIN_CI_DUMMY_MODEL=0
CT_BRAIN_DEVICE=cuda
CT_BRAIN_NCC_ENABLED=true
CT_BRAIN_MIDLINE_ENABLED=true
CT_BRAIN_GPU_IDLE_EMPTY_CACHE_SEC=0
CT_BRAIN_GPU_IDLE_CHECK_SEC=30
VISTA3D_MODEL_PATH=/models/vista3d/model.pt

# --- Brain MRI (02_brain_mri) ---
MONAI_DATA_DIRECTORY=/models/monai
MRI_NARRATIVE_POLICY=openrouter
MRI_NARRATIVE_VISION=1
MAX_UPLOAD_MB_BRAIN_MRI=512
TOTALSEG_DEVICE=gpu
WMH_MODEL_PATH=
BRAIN_LESION_MODEL_PATH=
SYNTHSEG_SCRIPT=/opt/SynthSeg/scripts/commands/SynthSeg_predict.py
PRIMA_CONFIG_YAML=
PRIMA_REPO_DIR=/opt/Prima

# --- Spine / abdominal / cardiac CT (TotalSegmentator + narratives) ---
CT_SPINE_NARRATIVE_POLICY=openrouter
CT_ABDOMINAL_NARRATIVE_POLICY=openrouter
CT_CARDIAC_NARRATIVE_POLICY=off
CT_TOTALSEG_IDLE_EMPTY_CACHE_SEC=0
CT_TOTALSEG_IDLE_CHECK_SEC=30

# --- Body X-ray (TorchXRayVision + narrative) ---
XRAY_REQUIRE_LLM_NARRATIVE=1
XRAY_MODEL_IDLE_UNLOAD_SEC=180
XRAY_UNLOAD_MODE=gpu_only
XRAY_MODEL_IDLE_CHECK_SEC=15

# --- Mammography (Mirai / HF) ---
MIRAI_HF_REPO=Lab-Rasool/Mirai

# --- Oral cancer — Modal GPU production default (14_oral_cancer) ---
ORAL_CANCER_ENABLED=true
UNI_MODEL_ID=MahmoodLab/UNI
ORAL_EFFNET_V2M_CHECKPOINT=oral_effnet_v2m.pt
ORAL_PREFER_V2M=
# Use numeric defaults — empty ORAL_V2M_NUM_CLASSES in Modal secret caused int('') crash before config fix.
ORAL_V2M_NUM_CLASSES=3
ORAL_V2M_BINARY_OPMD_FRACTION=0.45

# --- Lab report (15_lab_report) ---
USE_MEDGEMMA_PARSER=auto

# --- Dermatology (16_dermatology) ---
DERM_MAX_UPLOAD_BYTES=15728640
DERM_MAX_IMAGE_PIXELS=36000000
