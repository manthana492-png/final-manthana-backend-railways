{
  "overrides": [
    {
      "files": [
        "oracle-2/frontend-manthana/manthana/src/components/analyse/**/*.{ts,tsx}",
        "oracle-2/frontend-manthana/manthana/src/hooks/analyse/**/*.{ts,tsx}",
        "oracle-2/frontend-manthana/manthana/src/lib/analyse/**/*.{ts,tsx}",
        "oracle-2/frontend-manthana/manthana/src/app/(analyse)/**/*.{ts,tsx}"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["../lib/types", "../../lib/types"],
                "message": "Use shared @manthana/api types instead of per-app types."
              }
            ]
          }
        ]
      }
    }
  ]
}

